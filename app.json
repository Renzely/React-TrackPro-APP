{
  "expo": {
    "name": "BMP TrackPro",
    "slug": "RC_UGC",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/TrackPro-logo-notxt1.png",
    "scheme": "towi",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/TrackPro-logo-notxt1.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.bmp.RC_UGC"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/TrackPro-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4560472e-02fc-4bfd-9276-1b0e76e706d1"
      }
    },
    "owner": "harold16"
  }
}
